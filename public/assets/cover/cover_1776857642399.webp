                    <input type="text" id="company" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                </div>
                
                <div>
                    <label for="material" class="block text-sm font-medium text-gray-700 mb-1">需要处理的物料</label>
                    <select id="material" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                        <option value="">请选择物料类型</option>
                        <option value="plastic">塑料制品</option>
                        <option value="wood">木材/木托板</option>
                        <option value="metal">金属废料</option>
                        <option value="paper">纸张/纸箱</option>
                        <option value="e-waste">电子废弃物</option>
                        <option value="other">其他</option>
                    </select>
                </div>
                
                <div>
                    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">备注信息</label>
                    <textarea id="message" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"></textarea>
                </div>
                
                <div class="pt-2">
                    <button type="submit" class="w-full py-3 bg-blue-700 hover:bg-blue-800 text-white font-semibold rounded-lg transition duration-300 flex items-center justify-center">
                        <i class="fas fa-paper-plane mr-2"></i> 提交询盘
                    </button>
                </div>
                
                <p class="text-xs text-gray-500 text-center">提交后我们的销售顾问会在15分钟内联系您</p>
