                            <span>广东 · 深圳</span>
                        </div>
                    </div>
                </div>
                
                <!-- 案例3 -->
                <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                    <div class="h-48 bg-yellow-100 flex items-center justify-center">
                        <i class="fas fa-laptop text-yellow-500 text-6xl"></i>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-gray-900 mb-2">电子废弃物处理中心</h3>
                        <p class="text-gray-600 mb-4">使用我司单轴撕碎机处理电子废弃物，金属回收率达到95%以上。</p>
