            <i class="fas fa-phone-alt text-xl"></i>
        </a>
        <button id="floatingInquiryBtn" class="w-14 h-14 bg-red-600 rounded-full flex items-center justify-center text-white shadow-lg hover:bg-red-700 transition pulse">
            <i class="fas fa-comment-alt text-xl"></i>
        </button>
