        </a>
        <button id="floatingInquiryBtn" class="w-14 h-14 bg-cyan-700 rounded-full flex items-center justify-center text-white shadow-lg hover:bg-cyan-800 transition">
            <i class="fas fa-comment-alt text-xl"></i>
