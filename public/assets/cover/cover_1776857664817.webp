    <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
        document.addEventListener('DOMContentLoaded', function() {
            // 获取弹窗和按钮元素
            const modal = document.getElementById('inquiryModal');
            const openInquiryBtn = document.getElementById('openInquiryBtn');
            const openInquiryBtn2 = document.getElementById('openInquiryBtn2');
            const floatingInquiryBtn = document.getElementById('floatingInquiryBtn');
            const closeModalBtn = document.getElementById('closeModal');
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const mobileMenu = document.getElementById('mobileMenu');
            const viewAllProductsBtn = document.getElementById('viewAllProducts');
            const inquiryForm = document.getElementById('inquiryForm');
            const productModalButtons = document.querySelectorAll('.open-product-modal');
            
            // 打开弹窗的函数
            function openModal() {
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
            
            // 关闭弹窗的函数
            function closeModal() {
                modal.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
            
            // 绑定打开弹窗事件
            openInquiryBtn.addEventListener('click', openModal);
            openInquiryBtn2.addEventListener('click', openModal);
            floatingInquiryBtn.addEventListener('click', openModal);
            
            // 绑定关闭弹窗事件
            closeModalBtn.addEventListener('click', closeModal);
            
            // 点击弹窗外部关闭弹窗
            modal.addEventListener('click', function(event) {
                if (event.target === modal) {
                    closeModal();
                }
            });
            
            // 移动端菜单切换
            mobileMenuBtn.addEventListener('click', function() {
                mobileMenu.classList.toggle('hidden');
            });
            
            // 产品详情按钮点击事件
            productModalButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const productName = this.getAttribute('data-product');
                    // 设置设备类型到表单
                    const machineTypeSelect = document.getElementById('machineType');
                    
                    if (productName === "塑料造粒机") {
                        machineTypeSelect.value = "plastic";
                    } else if (productName === "饲料造粒机") {
                        machineTypeSelect.value = "feed";
                    } else if (productName === "有机肥造粒机") {
                        machineTypeSelect.value = "fertilizer";
                    } else {
                        machineTypeSelect.value = "other";
                    }
                    
                    // 在消息字段中预填产品信息
                    const messageField = document.getElementById('message');
                    messageField.value = `我对${productName}感兴趣，请提供详细资料和报价。\n\n`;
                    
                    // 打开弹窗
                    openModal();
                    
                    // 滚动到表单
                    setTimeout(() => {
                        document.getElementById('name').focus();
                    }, 300);
                });
            });
            
            // 查看所有产品按钮
            viewAllProductsBtn.addEventListener('click', function() {
                openModal();
            });
            
            // 表单提交处理
            inquiryForm.addEventListener('submit', function(event) {
                event.preventDefault();
                
                // 获取表单数据
                const formData = {
                    name: document.getElementById('name').value,
                    phone: document.getElementById('phone').value,
                    company: document.getElementById('company').value,
                    machineType: document.getElementById('machineType').value,
                    capacity: document.getElementById('capacity').value,
                    message: document.getElementById('message').value
                };
                
                // 这里应该发送到服务器
                console.log('询盘表单数据:', formData);
                
                // 显示成功消息
                alert('感谢您的咨询！我们的技术顾问将在15分钟内联系您。');
                
                // 关闭弹窗
                closeModal();
                
                // 重置表单
                inquiryForm.reset();
                
                // 设置标记，避免重复弹出
                localStorage.setItem('granulatorInquirySubmitted', 'true');
            });
            
            // 联系表单提交
            document.getElementById('contactForm').addEventListener('submit', function(e) {
                e.preventDefault();
                alert('您的需求已提交，我们将尽快与您联系！');
                this.reset();
            });
            
            // 页面加载后自动打开弹窗（延迟5秒）
            setTimeout(function() {
                // 检查是否已提交过表单
                const hasSubmitted = localStorage.getItem('granulatorInquirySubmitted');
                if (!hasSubmitted) {
                    openModal();
                }
            }, 5000);
            
            // 导航栏滚动效果
            const nav = document.querySelector('.sticky-nav');
            window.addEventListener('scroll', function() {
                if (window.scrollY > 100) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
            });
            
            // 平滑滚动到锚点
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    // 移动端菜单点击后关闭菜单
                    if (window.innerWidth < 768) {
                        mobileMenu.classList.add('hidden');
                    }
                    
                    const targetId = this.getAttribute('href');
                    if (targetId === '#') return;
                    
                    const targetElement = document.querySelector(targetId);
                    if (targetElement) {
                        e.preventDefault();
                        window.scrollTo({
                            top: targetElement.offsetTop - 80,
                            behavior: 'smooth'
                        });
                    }
                });
            });
            
            // 关闭移动端菜单当点击外部
            document.addEventListener('click', function(event) {
                if (!mobileMenu.contains(event.target) && !mobileMenuBtn.contains(event.target) && !mobileMenu.classList.contains('hidden')) {
                    mobileMenu.classList.add('hidden');
                }
            });
        });
    </script>
	<script src="https://registry.npmmirror.com/page-agent/1.7.1/files/dist/iife/page-agent.demo.js" crossorigin="true"></script>
</body>
</html>