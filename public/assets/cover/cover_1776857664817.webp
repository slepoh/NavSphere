                    <h3 class="text-2xl font-bold text-gray-900">免费获取报价</h3>
                    <p class="text-gray-600 text-sm mt-1">填写信息，我们将在15分钟内联系您</p>
                </div>
                <button id="closeModal" class="text-gray-500 hover:text-gray-800 text-2xl">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <form id="inquiryForm" class="space-y-4">
                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">姓名 *</label>
                    <input type="text" id="name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-600 focus:border-cyan-500 outline-none transition">
                </div>
                
                <div>
                    <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">联系电话 *</label>
                    <input type="tel" id="phone" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-600 focus:border-cyan-500 outline-none transition">
                </div>
                
                <div>
                    <label for="company" class="block text-sm font-medium text-gray-700 mb-1">公司名称</label>
                    <input type="text" id="company" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-600 focus:border-cyan-500 outline-none transition">
                </div>
                
                <div>
                    <label for="machineType" class="block text-sm font-medium text-gray-700 mb-1">设备类型 *</label>
                    <select id="machineType" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-600 focus:border-cyan-500 outline-none transition">
                        <option value="">请选择造粒机类型</option>
                        <option value="plastic">塑料造粒机</option>
                        <option value="feed">饲料造粒机</option>
                        <option value="fertilizer">有机肥造粒机</option>
                        <option value="chemical">生物质造粒机</option>
                        <option value="other">其他类型</option>
                    </select>
                </div>
                
                <div>
                    <label for="capacity" class="block text-sm font-medium text-gray-700 mb-1">预期产能 (kg/h)</label>
                    <select id="capacity" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-600 focus:border-cyan-500 outline-none transition">
                        <option value="">请选择预期产能</option>
                        <option value="100-500">100-500 kg/h</option>
                        <option value="500-1000">500-1000 kg/h</option>
                        <option value="1000-2000">1000-2000 kg/h</option>
                        <option value="2000+">2000+ kg/h</option>
                    </select>
                </div>
                
                <div>
                    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">具体要求</label>
                    <textarea id="message" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-600 focus:border-cyan-500 outline-none transition" placeholder="请描述您的具体需求..."></textarea>
                </div>
                
                <div class="pt-2">
                    <button type="submit" class="w-full py-3 bg-cyan-700 hover:bg-cyan-800 text-white font-semibold rounded-lg transition duration-300 flex items-center justify-center">
                        <i class="fas fa-paper-plane mr-2"></i> 立即获取报价
                    </button>
                </div>
                
                <p class="text-xs text-gray-500 text-center">提交后我们的技术顾问会立即联系您</p>
            </form>
        </div>
    </div>
    
